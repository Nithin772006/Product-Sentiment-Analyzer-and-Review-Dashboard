# ─────────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_NAME="Product Sentiment Analyzer"
APP_VERSION=1.0.0
DEBUG=true

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB  (choose one URI format)
# ─────────────────────────────────────────────────────────────────────────────
# Atlas (SRV)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
# Local
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentiment_analyzer
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# ─────────────────────────────────────────────────────────────────────────────
# Scraper Settings
# ─────────────────────────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true         # Run Chrome headless
SCRAPER_TIMEOUT=30            # Seconds to wait for page load
SCRAPER_DELAY_MIN=2           # Min seconds between requests (anti-ban)
SCRAPER_DELAY_MAX=5           # Max seconds between requests (anti-ban)
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ─────────────────────────────────────────────────────────────────────────────
# API Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60          # Seconds
